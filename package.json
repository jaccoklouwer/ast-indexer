{
  "name": "@klouwer94/ast-indexer",
  "version": "0.2.7",
  "description": "MCP Server for indexing Git repositories using AST parsing",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ast-indexer": "dist/index.js"
  },
  "files": [
    "dist",
    "mcp-manifest.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaccoklouwer/ast-indexer.git"
  },
  "homepage": "https://github.com/jaccoklouwer/ast-indexer#readme",
  "bugs": {
    "url": "https://github.com/jaccoklouwer/ast-indexer/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "watch": "tsc --watch -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "prepack": "pnpm build",
    "pack:dry-run": "npm pack --dry-run",
    "publish:npm:dry-run": "npm publish --dry-run",
    "publish:npm": "npm publish",
    "publish:check": "pnpm format:check && pnpm lint && pnpm build && pnpm test && pnpm run pack:dry-run",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "commit": "git add . && git-cz",
    "release": "standard-version --infile CHANGELOG.md",
    "push": "git push --follow-tags origin"
  },
  "keywords": [
    "AST",
    "Indexer",
    "CLI",
    "MCP",
    "MCP Server",
    "Git",
    "TypeScript"
  ],
  "author": "Jacco Klouwer",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "iconv-lite": "^0.7.3",
    "simple-git": "^3.36.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-sql": "^0.1.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "git-cz": "^4.9.0",
    "prettier": "^3.9.5",
    "standard-version": "^9.5.0",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
